{
  "manifest_version": 3,
  "name": "USOS Registration Bot",
  "version": "1.0",
  "description": "Automatyczna rejestracja na zajęcia USOSweb.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://*.usosweb.uj.edu.pl/*",
    "file:///*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*.usosweb.uj.edu.pl/*",
        "file:///*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_end"
    }
  ]
}